 // Macro bodies included by prim_assert.sv for tools that don't support assertions. See
 // prim_assert.sv for documentation for each of the macros.
 
-`define ASSERT_I(__name, __prop)
-`define ASSERT_INIT(__name, __prop)
-`define ASSERT_FINAL(__name, __prop)
-`define ASSERT(__name, __prop, __clk = `ASSERT_DEFAULT_CLK, __rst = `ASSERT_DEFAULT_RST)
-`define ASSERT_NEVER(__name, __prop, __clk = `ASSERT_DEFAULT_CLK, __rst = `ASSERT_DEFAULT_RST)
-`define ASSERT_KNOWN(__name, __sig, __clk = `ASSERT_DEFAULT_CLK, __rst = `ASSERT_DEFAULT_RST)
+// NOTE (TeraNoC): the optional `__desc` argument is added to mirror the
+// common_cells `assertions.svh` signatures. In the Verilator flow all RTL is
+// preprocessed in a single translation unit, so these dummy macros leak across
+// files and shadow the common_cells ones; without `__desc` a 5-argument
+// `ASSERT(...)` call (e.g. in floo_noc) fails with "too many arguments".
+`define ASSERT_I(__name, __prop, __desc = "")
+`define ASSERT_INIT(__name, __prop, __desc = "")
+`define ASSERT_FINAL(__name, __prop, __desc = "")
+`define ASSERT(__name, __prop, __clk = `ASSERT_DEFAULT_CLK, __rst = `ASSERT_DEFAULT_RST, __desc = "")
+`define ASSERT_NEVER(__name, __prop, __clk = `ASSERT_DEFAULT_CLK, __rst = `ASSERT_DEFAULT_RST, __desc = "")
+`define ASSERT_KNOWN(__name, __sig, __clk = `ASSERT_DEFAULT_CLK, __rst = `ASSERT_DEFAULT_RST, __desc = "")
 `define COVER(__name, __prop, __clk = `ASSERT_DEFAULT_CLK, __rst = `ASSERT_DEFAULT_RST)
-`define ASSUME(__name, __prop, __clk = `ASSERT_DEFAULT_CLK, __rst = `ASSERT_DEFAULT_RST)
-`define ASSUME_I(__name, __prop)
